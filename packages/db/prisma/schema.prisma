generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  createdAt     DateTime  @default(now())
  password      String?
  image         String?
  emailVerified DateTime?
  googleSecret  String?
  zaps          Zap[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       Int
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Zap {
  id         String    @unique @default(uuid())
  name       String    @default("New Zap")
  user       User?     @relation(fields: [userId], references: [id])
  userId     Int
  createdAt  DateTime  @default(now())
  finishedAt DateTime?
  trigger    Trigger?
  actions    Action[]
  zapRuns    ZapRun[]
}

model Trigger {
  id             Int              @id @default(autoincrement())
  availTriggerId Int
  zapId          String           @unique
  metadata       Json             @default("{}")
  zap            Zap              @relation(fields: [zapId], references: [id])
  type           AvailableTrigger @relation(fields: [availTriggerId], references: [id])
}

model AvailableTrigger {
  id             Int             @id @default(autoincrement())
  name           String
  imageUrl       String
  triggers       Trigger[]
  disabled       Boolean         @default(true)
  triggerOptions TriggerOption[]
}

model Action {
  id            Int    @id @default(autoincrement())
  zapId         String
  availActionId Int

  zap          Zap             @relation(fields: [zapId], references: [id])
  type         AvailableAction @relation(fields: [availActionId], references: [id])
  sortingOrder Int             @default(0)
  metadata     Json            @default("{}")
}

model AvailableAction {
  id            Int            @id @default(autoincrement())
  name          String
  imageUrl      String
  actions       Action[]
  disabled      Boolean        @default(true)
  actionOptions ActionOption[]
}

model ActionOption {
  id       Int             @id @default(autoincrement())
  actionid Int
  action   AvailableAction @relation(fields: [actionid], references: [id])
  name     String
}

model TriggerOption {
  id        Int              @id @default(autoincrement())
  triggerId Int
  action    AvailableTrigger @relation(fields: [triggerId], references: [id])
  name      String
}

enum ZapStatus {
  RUNNING
  PENDING
  COMPLETE
}

model ZapRun {
  id           Int           @id @default(autoincrement())
  zapId        String
  zap          Zap           @relation(fields: [zapId], references: [id])
  metadata     Json          @default("{}")
  zapRunOutbox ZapRunOutbox?
  status       ZapStatus     @default(PENDING)
  createdAt    DateTime      @default(now())
  finishedAt   DateTime?
}

model ZapRunOutbox {
  id       String @id @default(uuid())
  zapRunId Int    @unique
  zapRun   ZapRun @relation(fields: [zapRunId], references: [id])
}
