generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  password  String
  zaps      Zap[]
}

model Zap {
  id      String   @unique @default(uuid())
  user    User?    @relation(fields: [userId], references: [id])
  userId  Int
  trigger Trigger?
  actions Action[]
  zapRuns ZapRun[]
}

model Trigger {
  id             Int              @id @default(autoincrement())
  availTriggerId Int
  zapId          String           @unique
  metadata       Json             @default("{}")
  zap            Zap              @relation(fields: [zapId], references: [id])
  type           AvailableTrigger @relation(fields: [availTriggerId], references: [id])
}

model AvailableTrigger {
  id             Int             @id @default(autoincrement())
  name           String
  imageUrl       String
  triggers       Trigger[]
  disabled       Boolean         @default(true)
  triggerOptions TriggerOption[]
}

model Action {
  id            Int    @id @default(autoincrement())
  zapId         String
  availActionId Int

  zap          Zap             @relation(fields: [zapId], references: [id])
  type         AvailableAction @relation(fields: [availActionId], references: [id])
  sortingOrder Int             @default(0)
  metadata     Json            @default("{}")
}

model AvailableAction {
  id            Int            @id @default(autoincrement())
  name          String
  imageUrl      String
  actions       Action[]
  disabled      Boolean        @default(true)
  actionOptions ActionOption[]
}

model ActionOption {
  id       Int             @id @default(autoincrement())
  actionid Int
  action   AvailableAction @relation(fields: [actionid], references: [id])
  name     String
}

model TriggerOption {
  id        Int              @id @default(autoincrement())
  triggerId Int
  action    AvailableTrigger @relation(fields: [triggerId], references: [id])
  name      String
}

model ZapRun {
  id           Int           @id @default(autoincrement())
  zapId        String
  zap          Zap           @relation(fields: [zapId], references: [id])
  zapRunOutbox ZapRunOutbox?
}

model ZapRunOutbox {
  id       String @id @default(uuid())
  zapRunId Int    @unique
  zapRun   ZapRun @relation(fields: [zapRunId], references: [id])
}
